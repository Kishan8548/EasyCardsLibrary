<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurfaceVariant"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/card_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.example.easycards.EasyCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:ec_title="Maths"
                app:ec_description="Study nature, love nature,\nstay close to nature"
                app:ec_titleColor="@android:color/white"
                app:ec_descriptionColor="#E6FFFFFF"
                app:ec_backgroundGradientStart="#F55182"
                app:ec_backgroundGradientEnd="#AE67D5"
                app:ec_imageUrl="https://images.unsplash.com/photo-1509228468518-180dd4864904?auto=format&amp;fit=crop&amp;w=400&amp;q=80" />

            <com.example.easycards.EasyCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:ec_title="Physics"
                app:ec_description="Study nature, love nature,\nstay close to nature"
                app:ec_titleColor="@android:color/white"
                app:ec_descriptionColor="#E6FFFFFF"
                app:ec_backgroundGradientStart="#FFAB40"
                app:ec_backgroundGradientEnd="#FF7043"
                app:ec_imageUrl="https://images.unsplash.com/photo-1636466497217-26a8cbeaf0aa?auto=format&amp;fit=crop&amp;w=400&amp;q=80" />

            <com.example.easycards.EasyCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:ec_title="Chemistry"
                app:ec_description="Study nature, love nature,\nstay close to nature"
                app:ec_titleColor="@android:color/white"
                app:ec_descriptionColor="#E6FFFFFF"
                app:ec_backgroundGradientStart="#FFCA28"
                app:ec_backgroundGradientEnd="#FFA726"
                app:ec_imageUrl="https://images.unsplash.com/photo-1532094349884-543bc11b234d?auto=format&amp;fit=crop&amp;w=400&amp;q=80" />
                
            <com.example.easycards.EasyCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:cardCornerRadius="16dp"
                app:ec_title="Biology"
                app:ec_description="Study nature, love nature,\nstay close to nature"
                app:ec_titleColor="@android:color/white"
                app:ec_descriptionColor="#E6FFFFFF"
                app:ec_backgroundGradientStart="#FF8A65"
                app:ec_backgroundGradientEnd="#FFB74D"
                app:ec_imageUrl="https://images.unsplash.com/photo-1530213786676-412bd6710816?auto=format&amp;fit=crop&amp;w=400&amp;q=80" />

            <com.example.easycards.EasyCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:ec_title="Geography"
                app:ec_description="Study nature, love nature,\nstay close to nature"
                app:ec_imageUrl="https://images.unsplash.com/photo-1521295121783-8a321d551ad2?auto=format&amp;fit=crop&amp;w=400&amp;q=80" />
                
            <com.example.easycards.EasyCardView
                android:id="@+id/card_extra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:ec_title="Extra Curriculars"
                app:ec_description="Look, this card looks great by default without defining any colors!" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>